{
  "name": "jira-logger",
  "version": "0.1.1",
  "description": "CLI tool for logging time against Jira tickets",
  "type": "module",
  "bin": {
    "jira-logger": "./dist/index.js"
  },
  "scripts": {
    "build": "bun build --compile --outfile=dist/index.js --target=bun src/index.ts",
    "build:node": "bun build --outfile=dist/index.js --target=node src/index.ts",
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "log": "bun run src/index.ts log",
    "setup": "bun run src/index.ts setup",
    "install-skill": "bun run src/index.ts install-skill",
    "prepublishOnly": "bun run build"
  },
  "files": [
    "dist/",
    "src/",
    "skills/"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/steve228uk/jira-logger"
  },
  "keywords": [
    "jira",
    "time-tracking",
    "cli",
    "worklog",
    "developer-tools"
  ],
  "author": "Stephen Radford",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/steve228uk/jira-logger/issues"
  },
  "dependencies": {
    "inquirer": "^13.4.1",
    "jira.js": "^5.3.1"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "bun-types": "^1.3.0"
  }
}
